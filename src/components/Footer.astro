---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p>&copy; {year} Aatman Mantri. Built with <a href="https://astro.build" target="_blank">Astro</a>.</p>
    <div class="footer-links">
      <a href="https://github.com/AatmanMantri" target="_blank">GitHub</a>
    </div>
  </div>
</footer>
<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 2rem 0;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .footer-links {
    display: flex;
    gap: 1rem;
  }
  .footer-links a {
    color: var(--text-muted);
  }
  .footer-links a:hover {
    color: var(--accent);
  }
</style>
