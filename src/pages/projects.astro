---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    title: 'Distributed Social Network (Raft Consensus)',
    description: 'Built a fault-tolerant, distributed backend for a social networking application (Twitter clone) in Go. Implemented the Raft consensus algorithm from scratch for leader election and state machine replication, ensuring high availability and data consistency across nodes.',
    tags: ['Go', 'Raft', 'gRPC', 'etcd'],
    github: null,
    blogPost: '/blog/raft-consensus-go/',
    status: null,
  },
  {
    title: 'Panacea: Advanced Computer Vision Pipeline',
    description: 'Implemented classical computer vision algorithms from first principles without relying on high-level APIs. Showcases implementations of histogram equalization, complex image panorama stitching via cross-correlation, and optical flow estimation.',
    tags: ['Python', 'CV', 'Algorithms'],
    github: null,
    blogPost: null,
    status: 'Demo Soon',
  },
  {
    title: 'Cloud-Native Event Management Architecture',
    description: 'Designed and deployed a serverless, microservice-driven architecture on AWS. Architected data pipelines utilizing DynamoDB for transactional storage and Elasticsearch (OpenSearch) for advanced querying and text search.',
    tags: ['AWS', 'DynamoDB', 'Python', 'Serverless'],
    github: null,
    blogPost: null,
    status: null,
  },
  {
    title: 'Big Data: NYC Crime Analysis',
    description: 'Processed and analyzed large-scale NYPD shooting incident data using Hadoop MapReduce and PySpark. Generated geographic insights and visualized trends across NYC boroughs using interactive HTML/JS reports.',
    tags: ['Hadoop', 'Spark', 'MapReduce'],
    github: null,
    blogPost: null,
    status: null,
  },
  {
    title: 'Scent Universe',
    description: 'Interactive 3D visualization of perfume scents clustered by semantic UMAP embeddings. Explore 200+ perfumes in a 3D space where proximity reflects scent profile similarity. Built with React, Three.js, and D3.',
    tags: ['React', 'Three.js', 'UMAP', 'Data Viz'],
    github: 'https://github.com/aatmanmantri/scent-universe',
    blogPost: null,
    status: 'Live Demo',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Projects" description="Open-source projects and reference architectures by Aatman Mantri." />
  </head>
  <body>
    <Header />
    <main>
      <h1>Projects</h1>
      <p class="subtitle">Reference architectures and open-source work. Repos in progress — blogs come first.</p>

      <div class="project-list">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-header">
              <h2>{project.title}</h2>
              {project.status && <span class="badge">{project.status}</span>}
            </div>
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            {project.github && (
              <a href={project.github} target="_blank" class="github-link">
                View on GitHub &rarr;
              </a>
            )}
            {project.blogPost && (
              <a href={project.blogPost} class="github-link" style="margin-left: 1rem;">
                Read Blog Post &rarr;
              </a>
            )}
          </article>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .project-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .project-card:hover {
    border-color: var(--accent);
  }
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .project-header h2 {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    margin: 0;
    line-height: 1.4;
  }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--bg-code);
    color: var(--accent);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .project-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
  .github-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
