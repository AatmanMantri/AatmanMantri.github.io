---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <p class="greeting">Hi, I'm <span class="name">Aatman</span>.</p>
        <p class="tagline">I build backend systems and cloud infrastructure.</p>
        <p class="intro">
          I work on distributed systems, API performance, and Kubernetes at scale.
          I've built multi-service architectures in Go, optimized Django APIs from 48 database queries down to 1,
          and debugged everything from OOM-killing pods to cold storage orchestration for millions of medical images.
        </p>
        <p class="intro">
          This is where I write about the messy, interesting reality of production systems.
        </p>
      </section>

      <section class="recent-posts">
        <h2>Recent Posts</h2>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <span class="post-title">{post.data.title}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="see-all">All posts &rarr;</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .hero {
    padding: 2rem 0 3rem;
  }
  .greeting {
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .name {
    color: var(--accent);
  }
  .tagline {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .intro {
    font-size: 1.05rem;
    color: var(--text);
    max-width: 600px;
  }
  .recent-posts h2 {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    margin-top: 0;
  }
  .recent-posts ul {
    list-style: none;
    padding: 0;
  }
  .recent-posts li {
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
  }
  .recent-posts li:first-child {
    border-top: 1px solid var(--border);
  }
  .recent-posts a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 0;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }
  .recent-posts a:hover {
    color: var(--accent);
  }
  .post-title {
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }
  time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-shrink: 0;
    margin-left: 1rem;
  }
  .see-all {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
