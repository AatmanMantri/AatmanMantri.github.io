---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Scent Universe" description="Interactive 3D visualization of perfume scents clustered by semantic notes." />
  </head>
  <body>
    <Header />
    <main>
      <h1>Scent Universe</h1>
      <p class="subtitle">Interactive 3D visualization of perfume scents clustered by semantic notes.</p>
      
      <!-- Embed the React app -->
      <div style="width: 100%; height: 80vh; border: none;">
        <iframe 
          src="/scent-universe/index.html" 
          style="width: 100%; height: 100%; border: none;" 
          title="Scent Universe"
          allow="fullscreen"
        ></iframe>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
</style>
